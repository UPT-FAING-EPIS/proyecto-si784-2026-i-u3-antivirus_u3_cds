{
  "name": "rustguard-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot that uses RustGuard ClamAV engine to scan files",
  "main": "bot.js",
  "type": "module",
  "scripts": {
    "start": "node bot.js",
