    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2"
  }
}
