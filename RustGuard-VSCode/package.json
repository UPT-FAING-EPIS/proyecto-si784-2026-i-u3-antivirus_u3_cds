{
  "name": "rustguard-vscode",
  "displayName": "RustGuard Antivirus Scanner",
  "description": "Escanea archivos en busca de malware, virus y amenazas directamente desde VS Code. No requiere instalaciones externas.",
  "version": "1.0.3",
  "publisher": "jimmyllica1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rustguard-vscode.scanFile",
        "title": "Escanear con RustGuard Antivirus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rustguard-vscode.scanFile",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest --coverage",
    "test:bdd": "cucumber-js",
    "test:mutate": "stryker run"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.11.18",
    "@types/vscode": "^1.85.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
